{
    "name": "arthur-morechevalier/pattatras",
    "description": "Test technique CPAM — programme Pattatras (multiples de 3 et 5) en PHP, développé en TDD.",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10"
    },
    "autoload": {
        "psr-4": {
            "Pattatras\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pattatras\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
